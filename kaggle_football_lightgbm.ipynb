{\n  "cells": [\n    {\n      "cell_type": "code",\n      "execution_count": null,\n      "metadata": {},\n      "outputs": [],\n      "source": [\n        "# Importing necessary libraries\n        import pandas as pd\n        import lightgbm as lgb\n        from sklearn.metrics import mean_absolute_error\n        \n        # Load the datasets\n        train_data = pd.read_csv('train.csv')\n        test_data = pd.read_csv('test.csv')\n        \n        # Feature Engineering\n        features = ['team', 'opponent', 'team_goals', 'opp_goals', 'is_home', 'neutral', 'tournament',  \n                    'venue_country', 'elo_team', 'elo_opponent', 'rank_team', 'rank_opponent',  \n                    'team_points_last5', 'team_points_last10', 'team_gd_last5', 'team_win_rate_last10',  \n                    'h2h_points_last5', 'days_since_last_match', 'population_team', 'population_opponent',  \n                    'gdp_per_capita_team', 'gdp_per_capita_opponent', 'altitude_venue',  \n                    'distance_travel_team', 'distance_travel_opponent', 'temperature_venue',  \n                    'confederation_team', 'confederation_opponent']\n        \n        # Train LightGBM Model for team_goals\n        train_X = train_data[features]  \n        train_y_team_goals = train_data['team_goals']\n        train_dataset = lgb.Dataset(train_X, label=train_y_team_goals)\n        model_team_goals = lgb.train({}, train_dataset)\n        \n        # Train LightGBM Model for opp_goals\n        train_y_opp_goals = train_data['opp_goals']\n        model_opp_goals = lgb.train({}, train_dataset, label=train_y_opp_goals)\n        \n        # AW-MAE Metric Calculation\n        def calculate_aw_mae(y_true, y_pred, tournament):\n            weights = {'Friendly': 0.8, 'Qualifier': 1.0, 'Regional': 1.2, 'Major': 1.5}\n            bonuses = {'Exact': 0.10, 'Outcome': 0.05, 'GD': 0.05}\n            # Logic for weighted MAE calculation here\n            # Return perceived AW-MAE calculation based on predictions\n            return mean_absolute_error(y_true, y_pred)  # Placeholder\n        \n        # Handle missing values in the test set\n        test_data.fillna(method='ffill', inplace=True)  # Example implementation\n        \n        # Generate submission\n        test_X = test_data[features] \n        test_data['team_goals'] = model_team_goals.predict(test_X)\n        test_data['opp_goals'] = model_opp_goals.predict(test_X)\n        submission = test_data[['Id', 'team_goals', 'opp_goals']]\n        submission.to_csv('submission.csv', index=False)\n\n        "\n      ]\n    }\n  ],\n  "metadata": {},\n  "nbformat": 4,\n  "nbformat_minor": 2\n}