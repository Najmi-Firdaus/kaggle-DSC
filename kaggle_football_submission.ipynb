## Step 4: Custom AW-MAE Metric

def custom_aw_mae(y_true, y_pred, tournament_type):
    weights = {'Friendly': 0.8, 'Qualifier': 1.0, 'Regional': 1.2, 'Major': 1.5}
    weight = weights.get(tournament_type, 1)
    bonus_exact_score = 0.1 * (y_true == y_pred).sum()
    bonus_outcome = 0.05 * ((y_true > y_pred).sum() + (y_true < y_pred).sum())
    bonus_goal_difference = 0.05 * np.abs(y_true - y_pred).sum()

    return mean_absolute_error(y_true, y_pred) * weight - (bonus_exact_score + bonus_outcome + bonus_goal_difference)

